---
// FactPost enforces Vantage's signature device: exactly one highlighted fact
// per post. This is intentionally a hard build error, not a lint warning —
// the whole point of the device is that it stays rare. If a story needs two
// facts called out, it should be two posts.
interface Props {
  headline: string;
  highlight: string;
  category?: string;
}
const { headline, highlight, category = "Explained" } = Astro.props;

const parts = headline.split(highlight);
if (parts.length !== 2) {
  throw new Error(
    `FactPost: "highlight" must appear exactly once in "headline". ` +
    `Found ${parts.length - 1} occurrence(s) of "${highlight}" in "${headline}".`
  );
}
---
<article class="bg-ink border border-paper/15 rounded-lg p-5">
  <p class="text-[11px] font-semibold text-teal-light uppercase tracking-[0.08em] mb-2">{category}</p>
  <p class="text-base font-medium leading-snug text-paper">
    {parts[0]}<mark class="bg-teal-light text-teal-dark px-1 rounded-none">{highlight}</mark>{parts[1]}
  </p>
</article>
