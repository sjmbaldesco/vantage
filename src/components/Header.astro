---
import { NAV_LINKS } from '../consts';

const path = Astro.url.pathname;
// "/" matches only itself; section roots also match their child pages so an
// explainer detail page still marks "Explained" as current.
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`);
---
<header class="bg-ink">
  <div class="mx-auto max-w-3xl px-6 py-6 flex items-start justify-between">
    <a href="/" class="inline-block">
      <div class="text-2xl font-display font-bold tracking-tight text-paper leading-none">VANTAGE</div>
      <div class="h-[3px] w-14 bg-teal mt-2"></div>
    </a>
    <nav class="flex flex-wrap justify-end gap-x-6 gap-y-1 text-sm pt-1">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={[
            'hover:text-paper transition-colors',
            isActive(link.href) ? 'text-paper' : 'text-teal-light',
          ]}
        >{link.label}</a>
      ))}
    </nav>
  </div>
</header>
