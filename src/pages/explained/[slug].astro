---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const explainers = await getCollection('explainers');
  return explainers.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description, category, leadParagraph, highlight, drivers } = entry.data;

const leadParts = leadParagraph.split(highlight);
if (leadParts.length !== 2) {
  throw new Error(
    `Explainer "${entry.id}": "highlight" must appear exactly once in "leadParagraph". ` +
    `Found ${leadParts.length - 1} occurrence(s) of "${highlight}".`
  );
}
---
<Layout title={title} description={description}>
  <Header />
  <article class="max-w-2xl mx-auto px-6 py-12">
    <p class="text-xs font-medium text-teal-dark uppercase tracking-wide mb-3">{category}</p>
    <h1 class="text-3xl font-display font-bold text-ink leading-tight mb-6">{title}</h1>
    <p class="text-lg leading-relaxed text-ink/80 mb-4">
      {leadParts[0]}<mark class="bg-teal-light text-teal-dark px-1">{highlight}</mark>{leadParts[1]}
    </p>
    {drivers.map((driver) => (
      <>
        <h2 class="text-xl font-display font-semibold text-ink mt-8 mb-3">{driver.heading}</h2>
        <p class="text-base leading-relaxed text-ink/80 mb-4">{driver.body}</p>
      </>
    ))}
  </article>
</Layout>
