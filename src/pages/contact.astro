---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { CONTACT_EMAIL, FACEBOOK_URL } from '../consts';

const mailto = `mailto:${CONTACT_EMAIL}`;
---
<Layout title="Contact" description="Get in touch with Vantage — tips, corrections, and questions.">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-12">
    <p class="text-[11.5px] font-semibold text-teal-light uppercase tracking-[0.09em] mb-3">Contact</p>
    <h1 class="text-3xl font-display font-bold text-paper leading-tight mb-5">
      Get in touch
    </h1>
    <p class="text-lg leading-relaxed text-paper/70 mb-8">
      We're a small newsroom. Email is the fastest way to reach us — a real person will read it.
    </p>

    <a
      href={mailto}
      class="block bg-ink border border-paper/15 rounded-xl p-5 hover:border-teal transition-colors"
    >
      <p class="text-[11px] font-semibold text-teal-light uppercase tracking-[0.08em] mb-1.5">
        Editorial, tips &amp; general
      </p>
      <p class="text-[15px] font-medium text-teal-light">{CONTACT_EMAIL}</p>
    </a>

    <!-- The one highlight moment on the page — fact-first brands put the -->
    <!-- emphasis on getting corrected, not on the pitch. -->
    <div class="bg-teal-light rounded-xl p-5 mt-4">
      <p class="text-[11px] font-semibold text-teal-dark uppercase tracking-[0.08em] mb-2">Spotted an error?</p>
      <p class="text-sm leading-relaxed text-teal-dark mb-3">
        We correct the record fast and in the open. Send the piece and what's wrong.
      </p>
      <a href={mailto} class="text-sm font-semibold text-teal-dark underline underline-offset-2">
        {CONTACT_EMAIL}
      </a>
    </div>

    <div class="border-t border-paper/10 mt-7 pt-5">
      <a
        href={FACEBOOK_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-teal-light hover:text-paper transition-colors"
      >Message us on Facebook →</a>
    </div>
  </main>
</Layout>
