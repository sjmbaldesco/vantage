---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="About" description="Who's behind Vantage.">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-12">
    <p class="text-[11.5px] font-semibold text-teal-light uppercase tracking-[0.09em] mb-3">About</p>
    <h1 class="text-3xl font-display font-bold text-paper leading-tight mb-5">
      Who's behind Vantage
    </h1>
    <p class="text-lg leading-relaxed text-paper/70 mb-8">
      [Placeholder mission statement — replace with the real masthead intro copy.]
    </p>
    <h2 class="text-xl font-display font-bold text-paper mt-8 mb-4">Masthead</h2>
    <ul class="grid gap-4">
      <li class="bg-ink border border-paper/15 rounded-xl p-4">
        <p class="font-medium text-paper">[Editor-in-Chief Name]</p>
        <p class="text-sm text-paper/60">[Editor-in-Chief]</p>
      </li>
      <li class="bg-ink border border-paper/15 rounded-xl p-4">
        <p class="font-medium text-paper">[Reporter Name]</p>
        <p class="text-sm text-paper/60">[Staff Reporter]</p>
      </li>
      <li class="bg-ink border border-paper/15 rounded-xl p-4">
        <p class="font-medium text-paper">[Fact-Checker Name]</p>
        <p class="text-sm text-paper/60">[Fact-Checking Lead]</p>
      </li>
    </ul>
  </main>
</Layout>
