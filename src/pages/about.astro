---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="About" description="Who's behind Vantage.">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-12">
    <p class="text-xs font-medium text-teal-dark uppercase tracking-wide mb-3">About</p>
    <h1 class="text-3xl font-display font-bold text-ink leading-tight mb-6">
      Who's behind Vantage
    </h1>
    <p class="text-lg leading-relaxed text-ink/80 mb-8">
      [Placeholder mission statement — replace with the real masthead intro copy.]
    </p>
    <h2 class="text-xl font-display font-semibold text-ink mt-8 mb-4">Masthead</h2>
    <ul class="grid gap-4">
      <li class="border border-ink/10 rounded-lg p-4">
        <p class="font-medium text-ink">[Editor-in-Chief Name]</p>
        <p class="text-sm text-ink/60">[Editor-in-Chief]</p>
      </li>
      <li class="border border-ink/10 rounded-lg p-4">
        <p class="font-medium text-ink">[Reporter Name]</p>
        <p class="text-sm text-ink/60">[Staff Reporter]</p>
      </li>
      <li class="border border-ink/10 rounded-lg p-4">
        <p class="font-medium text-ink">[Fact-Checker Name]</p>
        <p class="text-sm text-ink/60">[Fact-Checking Lead]</p>
      </li>
    </ul>
  </main>
</Layout>
