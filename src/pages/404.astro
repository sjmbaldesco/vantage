---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="Page not found" description="The page you're looking for doesn't exist.">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-20 text-center">
    <p class="text-xs font-medium text-teal-dark uppercase tracking-wide mb-3">Error 404</p>
    <h1 class="text-4xl font-display font-bold text-ink leading-tight mb-6">
      This page doesn't exist.
    </h1>
    <p class="text-lg leading-relaxed text-ink/80 mb-8">
      The story you're looking for may have moved, or the link may be broken.
    </p>
    <a
      href="/"
      class="inline-block bg-teal text-paper font-medium px-5 py-3 rounded-lg hover:bg-teal-dark transition-colors"
    >
      Back to the feed
    </a>
  </main>
</Layout>
