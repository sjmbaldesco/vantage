---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="Page not found" description="The page you're looking for doesn't exist.">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-20 text-center">
    <p class="text-[11.5px] font-semibold text-teal-light uppercase tracking-[0.09em] mb-3">Error 404</p>
    <h1 class="text-4xl font-display font-bold text-paper leading-tight mb-6">
      This page doesn't exist.
    </h1>
    <p class="text-lg leading-relaxed text-paper/70 mb-8">
      The story you're looking for may have moved, or the link may be broken.
    </p>
    <a
      href="/"
      class="inline-block bg-teal-light text-ink font-medium px-5 py-3 rounded-lg hover:bg-paper transition-colors"
    >
      Back to the feed
    </a>
  </main>
</Layout>
